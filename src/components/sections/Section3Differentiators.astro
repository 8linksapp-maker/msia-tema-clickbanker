---
import { getCollection } from 'astro:content';
import SectionHeader from '../ui/SectionHeader.astro';
import PostCardMedium from '../ui/PostCardMedium.astro';
import { readData } from '../../lib/readData';

interface Props {
  title?: string;
  image?: string;
  items?: Array<{ title: string; desc: string }>;
}

const home = readData<any>('home.json', {});
const { title = home?.sections?.trending?.heading || 'Trending This Week' } = Astro.props;

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

// Pega os posts a partir do índice 1 para não repetir o featured
const trendingPosts = posts.slice(1, 5);
---

{trendingPosts.length > 0 && (
  <section class="py-12 bg-white border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-4">
      <SectionHeader title={title} />

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {trendingPosts.map(post => (
          <PostCardMedium
            title={post.data.title}
            description={post.data.description}
            slug={post.slug}
            heroImage={post.data.heroImage}
            category={post.data.category}
            pubDate={post.data.pubDate}
          />
        ))}
      </div>
    </div>
  </section>
)}
