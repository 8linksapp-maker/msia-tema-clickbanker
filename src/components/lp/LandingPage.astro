<script is:inline>
  (function() {
    function pad(n) { return n < 10 ? '0' + n : String(n); }
    function tick(el) {
      const target = new Date(el.dataset.target).getTime();
      const now = Date.now();
      const diff = target - now;
      const display = el.querySelector('[data-countdown-display]');
      const expired = el.querySelector('[data-countdown-expired]');
      if (diff <= 0) {
        if (display) display.style.display = 'none';
        if (expired) expired.style.display = 'inline-block';
        return false;
      }
      const d = Math.floor(diff / 86400000);
      const h = Math.floor((diff % 86400000) / 3600000);
      const m = Math.floor((diff % 3600000) / 60000);
      const s = Math.floor((diff % 60000) / 1000);
      const setVal = (sel, v) => { const e = el.querySelector('[' + sel + ']'); if (e) e.textContent = pad(v); };
      setVal('data-d', d);
      setVal('data-h', h);
      setVal('data-m', m);
      setVal('data-s', s);
      return true;
    }
    document.querySelectorAll('.lp-countdown').forEach(el => {
      const ok = tick(el);
      if (ok) setInterval(() => tick(el), 1000);
    });
  })();
</script>
