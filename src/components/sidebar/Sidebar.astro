---
import { getCollection } from 'astro:content';
import { readData } from '../../lib/readData';
import { slugify } from '../../lib/slugify';

const siteConfig = readData('siteConfig.json');
const homeData = readData('home.json', {});
const featuredProducts = readData('featuredProducts.json', []) as any[];

const allPosts = await getCollection('blog');
const recentPosts = allPosts
  .sort((a: any, b: any) => {
    const da = new Date(a.data.pubDate || a.data.date || 0).getTime();
    const db = new Date(b.data.pubDate || b.data.date || 0).getTime();
    return db - da;
  })
  .slice(0, 5);

const categoriesData = readData('categories.json', []);
const finalCategoriesData = Array.isArray(categoriesData) ? categoriesData : [];
const categoriesFromPosts = [...new Set(allPosts.map((p: any) => p.data.category).filter(Boolean))];
const allCategories: string[] = finalCategoriesData.length > 0 ? finalCategoriesData : categoriesFromPosts;

const highlight = (homeData as any)?.sidebar?.highlight;
const products = Array.isArray(featuredProducts) ? featuredProducts.slice(0, 3) : [];

function fmtDate(d: any): string {
  if (!d) return '';
  const dt = new Date(d);
  if (isNaN(dt.getTime())) return '';
  return dt.toLocaleDateString('pt-BR', { month: 'short', day: '2-digit' }).replace('.', '');
}
---

<aside class="lg:sticky lg:top-24 space-y-12">

  <!-- ===== Produtos em destaque (ClickBank widget) ===== -->
  {products.length > 0 && (
    <div class="side-section">
      <div class="side-section-label uppercase">produtos em destaque</div>
      <div class="space-y-3">
        {products.map((product: any) => (
          <a href={product.link || '#'} class="product-card group" target="_blank" rel="noopener nofollow sponsored">
            <div class="flex items-start justify-between gap-2">
              <h4 class="font-display text-base font-bold text-ink leading-tight group-hover:text-primary transition-colors">
                {product.name}
              </h4>
              {product.rating && (
                <span class="mono text-ink-faint shrink-0">★ {product.rating}</span>
              )}
            </div>
            {product.category && (
              <p class="mono uppercase text-ink-faint">{product.category}</p>
            )}
            {product.blurb && (
              <p class="text-sm text-ink-muted leading-relaxed">{product.blurb}</p>
            )}
            <div class="flex items-center justify-between pt-2 border-t border-border mt-1">
              <span class="font-display text-base font-bold text-primary">{product.price}</span>
              <span class="mono uppercase text-ink-faint inline-flex items-center gap-1 group-hover:text-primary transition-colors">
                ver
                <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg>
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  )}

  <!-- ===== Posts recentes ===== -->
  <div class="side-section">
    <div class="side-section-label uppercase">recente</div>
    <ol class="space-y-5">
      {recentPosts.map((post: any, i: number) => {
        const data = post.data;
        const slug = post.slug ?? post.id;
        const date = data.pubDate || data.date;
        const num = String(i + 1).padStart(2, '0');
        return (
          <li>
            <a href={`/${slug}`} class="group block">
              <div class="flex items-baseline gap-3 mb-1">
                <span class="mono text-ink-faint">{num}</span>
                {date && <span class="mono text-ink-faint">{fmtDate(date)}</span>}
              </div>
              <h4 class="font-display text-[15px] font-semibold leading-snug text-ink group-hover:text-primary transition-colors line-clamp-2">
                {data.title}
              </h4>
            </a>
          </li>
        );
      })}
    </ol>
  </div>

  <!-- ===== Tópicos ===== -->
  {allCategories.length > 0 && (
    <div class="side-section">
      <div class="side-section-label uppercase">tópicos</div>
      <ul class="flex flex-wrap gap-x-3 gap-y-2">
        {allCategories.map((cat: string) => (
          <li>
            <a href={`/categoria/${slugify(cat)}`} class="mono text-ink-muted hover:text-ink transition-colors">
              {cat.toLowerCase()}
            </a>
          </li>
        ))}
      </ul>
    </div>
  )}

  <!-- ===== Highlight opcional ===== -->
  {highlight && highlight.title && highlight.href && (
    <div class="side-section">
      <div class="side-section-label uppercase">{highlight.label || 'destaque'}</div>
      <h3 class="font-display text-lg font-bold text-ink leading-snug mb-2">
        {highlight.title}
      </h3>
      {highlight.description && (
        <p class="text-sm text-ink-muted leading-relaxed mb-3">
          {highlight.description}
        </p>
      )}
      <a href={highlight.href} class="mono text-ink hover:text-primary transition-colors inline-flex items-center gap-1.5 border-b border-ink hover:border-primary pb-0.5">
        {highlight.cta || 'continuar'}
        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </a>
    </div>
  )}
</aside>
