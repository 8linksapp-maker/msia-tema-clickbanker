---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { readData } from '../lib/readData';
import { colorForCategory, CATEGORY_ORDER } from '../lib/categoryColors';

const siteConfig = readData('siteConfig.json');
const homeData = readData('home.json', {}) as any;

const allPosts = await getCollection('blog');

// Ordena por CATEGORY_ORDER (Comece aqui → Configuração → ...) ao invés de data
// pra garantir que o scaffold tem ordem narrativa, não cronológica
function orderForCategory(cat: string | undefined) {
  if (!cat) return 999;
  const idx = CATEGORY_ORDER.indexOf(cat);
  return idx >= 0 ? idx : 999;
}

const posts = allPosts.sort((a: any, b: any) => {
  const oa = orderForCategory(a.data.category);
  const ob = orderForCategory(b.data.category);
  if (oa !== ob) return oa - ob;
  return new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime();
});

const featured = posts[0];
const rest = posts.slice(1, 5);

function fmtShort(d: any): string {
  if (!d) return '';
  const dt = new Date(d);
  if (isNaN(dt.getTime())) return '';
  return dt.toLocaleDateString('pt-BR', { day: '2-digit', month: '2-digit', year: '2-digit' });
}

const heroTitle = homeData?.hero?.title || siteConfig.name;
const heroEyebrow = homeData?.hero?.eyebrow || 'scaffold msia';
const heroLead = homeData?.hero?.lead || 'Cinco passos pra deixar este blog seu. Cada bloco é um capítulo.';
---

<BaseLayout title={siteConfig.name} description={siteConfig.description}>

  <!-- ===== HERO: tipografia dominante ===== -->
  <section class="border-b border-rule">
    <div class="container-x pt-16 md:pt-24 pb-14 md:pb-20">
      <div class="grid grid-cols-1 md:grid-cols-12 gap-8 md:gap-12 items-end">
        <div class="md:col-span-8">
          <p class="mono uppercase text-ink-faint mb-6">{heroEyebrow} · {new Date().getFullYear()}</p>
          <h1 class="font-display text-5xl md:text-7xl lg:text-8xl font-extrabold text-ink leading-[0.92] tracking-tight">
            {heroTitle}
          </h1>
        </div>
        <div class="md:col-span-4 md:pb-3">
          <p class="text-lg text-ink-muted leading-relaxed max-w-md">
            {heroLead}
          </p>
        </div>
      </div>
    </div>
  </section>

  {posts.length === 0 ? (
    <div class="container-x py-32">
      <p class="mono uppercase text-ink-faint mb-3">vazio</p>
      <h2 class="font-display text-3xl text-ink mb-3">Nenhum post publicado.</h2>
      <p class="text-ink-muted">Crie o primeiro em <a href="/admin" class="text-primary underline underline-offset-4">/admin</a>.</p>
    </div>
  ) : (
    <>
      <!-- ===== BLOCOS COLORIDOS — grid asymmetric ===== -->
      <section class="border-b border-rule">
        <div class="container-x py-10 md:py-14">
          <div class="grid grid-cols-1 md:grid-cols-12 gap-3 md:gap-4">

            {/* Bloco destaque — ocupa 8 colunas */}
            {featured && (() => {
              const c = colorForCategory(featured.data.category, 0);
              const slug = featured.slug ?? featured.id;
              return (
                <a href={`/${slug}`} class={`md:col-span-8 color-block color-block-lg bg-cat-${c} group`}>
                  <span class="color-block-num">01</span>
                  <div>
                    <p class="mono uppercase opacity-80 mb-6">
                      {featured.data.category} · {fmtShort(featured.data.pubDate)}
                    </p>
                    <h2 class="font-display text-4xl md:text-5xl lg:text-6xl font-extrabold leading-[1.02] tracking-tight max-w-2xl">
                      {featured.data.title}
                    </h2>
                  </div>
                  <div class="flex items-end justify-between gap-4 mt-10">
                    {featured.data.description && (
                      <p class="text-base md:text-lg leading-relaxed max-w-md opacity-90 line-clamp-3">
                        {featured.data.description}
                      </p>
                    )}
                    <span class="mono uppercase shrink-0 self-end inline-flex items-center gap-2 border-b border-current pb-1 group-hover:gap-3 transition-all">
                      começar
                      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                    </span>
                  </div>
                </a>
              );
            })()}

            {/* Coluna direita — 2 blocos médios empilhados */}
            <div class="md:col-span-4 grid grid-cols-1 gap-3 md:gap-4">
              {rest.slice(0, 2).map((post: any, i: number) => {
                const c = colorForCategory(post.data.category, i + 1);
                const slug = post.slug ?? post.id;
                const num = String(i + 2).padStart(2, '0');
                return (
                  <a href={`/${slug}`} class={`color-block color-block-md bg-cat-${c} group`}>
                    <span class="color-block-num">{num}</span>
                    <div>
                      <p class="mono uppercase opacity-80 mb-3">{post.data.category}</p>
                      <h3 class="font-display text-xl md:text-2xl font-bold leading-[1.1] tracking-tight">
                        {post.data.title}
                      </h3>
                    </div>
                    <span class="mono uppercase mt-4 inline-flex items-center gap-2 self-start border-b border-current pb-1 group-hover:gap-3 transition-all">
                      abrir
                      <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                    </span>
                  </a>
                );
              })}
            </div>

            {/* Segunda linha — 2 blocos de 6 colunas cada */}
            {rest.slice(2, 4).map((post: any, i: number) => {
              const c = colorForCategory(post.data.category, i + 3);
              const slug = post.slug ?? post.id;
              const num = String(i + 4).padStart(2, '0');
              return (
                <a href={`/${slug}`} class={`md:col-span-6 color-block color-block-md bg-cat-${c} group`}>
                  <span class="color-block-num">{num}</span>
                  <div>
                    <p class="mono uppercase opacity-80 mb-3">{post.data.category}</p>
                    <h3 class="font-display text-2xl md:text-3xl font-bold leading-[1.05] tracking-tight max-w-md">
                      {post.data.title}
                    </h3>
                  </div>
                  <div class="flex items-end justify-between gap-4 mt-6">
                    {post.data.description && (
                      <p class="text-sm md:text-base leading-relaxed max-w-xs opacity-85 line-clamp-2">
                        {post.data.description}
                      </p>
                    )}
                    <span class="mono uppercase shrink-0 inline-flex items-center gap-2 border-b border-current pb-1 group-hover:gap-3 transition-all">
                      abrir
                      <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                    </span>
                  </div>
                </a>
              );
            })}
          </div>
        </div>
      </section>

      <!-- ===== Footer da home: link pra archive ===== -->
      <section class="border-b border-rule">
        <div class="container-x py-14 md:py-20 text-center">
          <p class="mono uppercase text-ink-faint mb-4">tem mais</p>
          <a href="/blog" class="font-display text-3xl md:text-4xl font-bold text-ink hover:text-primary transition-colors inline-flex items-center gap-3">
            todos os artigos
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
        </div>
      </section>
    </>
  )}
</BaseLayout>
