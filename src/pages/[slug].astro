---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { readData } from '../lib/readData';
import { colorForCategory } from '../lib/categoryColors';
import { normalizeCategories, getCategorySlug } from '../lib/categorySlug';

const allCategoriesForLinks = normalizeCategories(readData('categories.json', []));
import { findProductBySlug } from '../lib/products';
import type { Product } from '../lib/products';
import { renderShortcodes } from '../lib/shortcodes';
import ProductCard from '../components/ui/ProductCard.astro';
import ProductComparator from '../components/ui/ProductComparator.astro';
import ReviewSchema from '../components/ui/ReviewSchema.astro';
import PostVideo from '../components/ui/PostVideo.astro';
import { parseVideoUrl } from '../lib/videoEmbed';

export async function getStaticPaths() {
  const siteConfig = readData('siteConfig.json', {}) as any;
  // Quando aluno escolheu prefixo /blog, esta rota nao gera (evita duplicacao com /blog/[slug]).
  if (siteConfig?.postUrlPrefix === 'blog') return [];
  const posts = await getCollection('blog');
  return posts.map((post: any) => ({
    params: { slug: post.slug ?? post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
const data = post.data;

const siteConfig = readData('siteConfig.json');
const allProducts = readData('products.json', []) as Product[];

// Processa shortcodes [[produto:slug]] e [[comparador:a,b,c]] no body do post
// Se body já é HTML (Quill output), passamos direto; senão Content cuida via markdown.
const rawBody = (post.body || '') as string;
const hasShortcodes = /\[\[\s*(produto|comparador)\s*:/i.test(rawBody);
const isHtmlBody = /^\s*</.test(rawBody.trim());
const processedHtml = hasShortcodes && isHtmlBody
  ? renderShortcodes(rawBody, allProducts)
  : null;

const catColor = colorForCategory(data.category);

// Resolve produtos referenciados pelo frontmatter
const mainProduct = data.productSlug ? findProductBySlug(allProducts, data.productSlug) : null;

const comparedProducts = (data.comparedProductSlugs || [])
  .map((s: string) => findProductBySlug(allProducts, s))
  .filter(Boolean) as Product[];

const featuredProducts = (data.featuredProductSlugs || [])
  .map((s: string) => findProductBySlug(allProducts, s))
  .filter(Boolean) as Product[];

function fmtDate(d: any): string {
  if (!d) return '';
  const dt = new Date(d);
  if (isNaN(dt.getTime())) return '';
  return dt.toLocaleDateString('pt-BR', { year: 'numeric', month: 'long', day: '2-digit' });
}

const readingMinutes = (() => {
  try {
    const text = (post.body || '') as string;
    const words = text.split(/\s+/).length;
    return Math.max(1, Math.round(words / 200));
  } catch { return 5; }
})();

const allPosts = await getCollection('blog');
const otherPosts = allPosts.filter((p: any) => (p.slug ?? p.id) !== (post.slug ?? post.id));
const related = otherPosts.slice(0, 3);

const postUrl = `${siteConfig.url || Astro.url.origin}/${post.slug ?? post.id}`;
const isUpdated = data.updatedDate && new Date(data.updatedDate).getTime() > new Date(data.pubDate).getTime();

const videoUrl = data.videoUrl || '';
const videoInfo = videoUrl ? parseVideoUrl(videoUrl) : null;
const hasValidVideo = videoInfo && videoInfo.provider !== 'unknown';
const videoPosition = data.videoPosition || 'after-hero';
---

<BaseLayout
  title={data.title}
  description={data.description || ''}
  image={data.heroImage || ''}
  type="article"
>
  {mainProduct && (
    <ReviewSchema
      product={mainProduct}
      postTitle={data.title}
      postUrl={postUrl}
      publishedDate={new Date(data.pubDate)}
      updatedDate={data.updatedDate ? new Date(data.updatedDate) : undefined}
      authorName={data.author}
    />
  )}

  <article>
    <!-- HERO BLOCK -->
    <header class={`bg-cat-${catColor} relative overflow-hidden isolate`}>
      <span class="color-block-num" style="bottom:-4rem;right:-2rem;font-size:clamp(16rem,40vw,32rem)">
        {String(data.order || '#').padStart(2, '0')}
      </span>

      <div class="container-x relative z-10 pt-16 md:pt-24 pb-20 md:pb-28">
        <nav class="mono opacity-75 mb-12" aria-label="Breadcrumb">
          <a href="/" class="hover:opacity-100 transition-opacity">início</a>
          <span class="mx-2 opacity-60">/</span>
          {data.category && (
            <>
              <a href={`/categoria/${getCategorySlug(data.category, allCategoriesForLinks)}`} class="hover:opacity-100 transition-opacity uppercase">
                {data.category}
              </a>
              <span class="mx-2 opacity-60">/</span>
            </>
          )}
          <span class="opacity-100">leitura atual</span>
        </nav>

        <h1 class="font-display text-5xl md:text-6xl lg:text-7xl font-extrabold leading-[0.98] tracking-tight text-white max-w-4xl mb-8">
          {data.title}
        </h1>

        {data.description && (
          <p class="text-xl md:text-2xl leading-snug max-w-3xl text-white/85 mb-12">
            {data.description}
          </p>
        )}

        <div class="mono uppercase text-white/70 flex items-center gap-3 flex-wrap pt-6 border-t border-white/20">
          <span>{fmtDate(data.pubDate)}</span>
          {isUpdated && (
            <>
              <span class="opacity-50">·</span>
              <span class="text-white">atualizado em {fmtDate(data.updatedDate)}</span>
            </>
          )}
          <span class="opacity-50">·</span>
          <span>{readingMinutes} min</span>
          {data.author && (<><span class="opacity-50">·</span><span>por {data.author}</span></>)}
        </div>
      </div>
    </header>

    {hasValidVideo && videoPosition === 'hero' ? (
      <div class="border-b border-rule">
        <div class="container-x py-8">
          <PostVideo
            url={videoUrl}
            title={data.title}
            description={data.description}
            uploadDate={data.pubDate instanceof Date ? data.pubDate.toISOString() : String(data.pubDate)}
            lite={true}
          />
        </div>
      </div>
    ) : data.heroImage ? (
      <div class="border-b border-rule">
        <div class="container-x py-8">
          <img
            src={data.heroImage}
            alt=""
            class="w-full aspect-[21/9] object-cover"
            loading="eager"
          />
        </div>
      </div>
    ) : null}

    {hasValidVideo && videoPosition === 'after-hero' && (
      <div class="border-b border-rule">
        <div class="container-x py-8">
          <PostVideo
            url={videoUrl}
            title={data.title}
            description={data.description}
            uploadDate={data.pubDate instanceof Date ? data.pubDate.toISOString() : String(data.pubDate)}
            lite={true}
          />
        </div>
      </div>
    )}

    <!-- DISCLAIMER per-post (compliance afiliado) -->
    {data.affiliate && (
      <div class="border-b border-rule bg-elev/40">
        <div class="container-x py-3">
          <p class="text-xs text-ink-muted leading-relaxed text-center md:text-left">
            <span class="mono uppercase text-ink-faint mr-2">aviso</span>
            Este artigo contém links de afiliado. Compras podem gerar comissão sem custo adicional pra você. Recomendamos apenas produtos analisados.
          </p>
        </div>
      </div>
    )}

    <!-- CONTEÚDO -->
    <div class="container-x py-16 md:py-24">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16">
        <div class="lg:col-span-8 lg:col-start-2">

          {/* Hero do produto (se for review específica) */}
          {mainProduct && <ProductCard product={mainProduct} variant="hero" />}

          <div class="prose-msia max-w-none">
            {processedHtml ? (
              <Fragment set:html={processedHtml} />
            ) : (
              <Content />
            )}
          </div>

          {/* Tabela comparativa */}
          {comparedProducts.length > 0 && (
            <ProductComparator products={comparedProducts} title="Comparação rápida" />
          )}

          {/* Produtos recomendados no fim */}
          {featuredProducts.length > 0 && (
            <div class="not-prose mt-12 pt-10 border-t border-rule">
              <p class="mono uppercase text-ink-faint mb-5">recomendado</p>
              <div class="space-y-4">
                {featuredProducts.map((p) => (
                  <ProductCard product={p} variant="inline" />
                ))}
              </div>
            </div>
          )}

        </div>
      </div>
    </div>

    <!-- POSTS RELACIONADOS -->
    {related.length > 0 && (
      <section class="border-t border-rule">
        <div class="container-x py-14 md:py-20">
          <p class="mono uppercase text-ink-faint mb-8">continuar lendo</p>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-3 md:gap-4">
            {related.map((p: any, i: number) => {
              const c = colorForCategory(p.data.category, i);
              const s = p.slug ?? p.id;
              return (
                <a href={`/${s}`} class={`color-block color-block-md bg-cat-${c} group`}>
                  <span class="color-block-num">{String(i + 1).padStart(2, '0')}</span>
                  <div>
                    <p class="mono uppercase opacity-80 mb-3">{p.data.category}</p>
                    <h3 class="font-display text-xl md:text-2xl font-bold leading-[1.1] tracking-tight">
                      {p.data.title}
                    </h3>
                  </div>
                  <span class="mono uppercase mt-4 inline-flex items-center gap-2 self-start border-b border-current pb-1 group-hover:gap-3 transition-all">
                    abrir
                    <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                  </span>
                </a>
              );
            })}
          </div>
        </div>
      </section>
    )}
  </article>
</BaseLayout>
